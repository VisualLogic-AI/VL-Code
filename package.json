{
  "name": "vl-code",
  "version": "0.9.1",
  "description": "AI-powered IDE for Visual Language (VL) v2.91 — full-stack declarative development",
  "type": "module",
  "bin": {
    "vl-code": "./bin/vl-code.js"
  },
  "main": "src/index.js",
  "scripts": {
    "start": "node bin/vl-code.js",
    "web": "node bin/vl-code.js --web",
    "dev": "node bin/vl-code.js --web --port 3200",
    "setup": "bash install.sh",
    "build": "node scripts/build.js"
  },
  "keywords": [
    "vl",
    "visual-language",
    "ide",
    "ai",
    "code-generation",
    "low-code"
  ],
  "author": "VisualLogic-AI",
  "license": "MIT",
  "homepage": "https://github.com/VisualLogic-AI/VL-Code",
  "repository": {
    "type": "git",
    "url": "https://github.com/VisualLogic-AI/VL-Code.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "codemirror": "^5.65.18",
    "express": "^4.22.1",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "javascript-obfuscator": "^5.3.0"
  }
}
